{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.NyxToolsDev/quickbooks-mcp-server",
  "description": "Connect Claude to QuickBooks Online — query finances, create invoices, run reports",
  "version": "0.1.1",
  "repository": {
    "url": "https://github.com/NyxToolsDev/quickbooks-mcp-server",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "quickbooks-mcp",
      "version": "0.1.1",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "environmentVariables": [
    {
      "name": "QBO_CLIENT_ID",
      "description": "QuickBooks Online OAuth2 client ID",
      "isRequired": true,
      "isSecret": true
    },
    {
      "name": "QBO_CLIENT_SECRET",
      "description": "QuickBooks Online OAuth2 client secret",
      "isRequired": true,
      "isSecret": true
    },
    {
      "name": "QBO_REFRESH_TOKEN",
      "description": "QuickBooks Online OAuth2 refresh token",
      "isRequired": true,
      "isSecret": true
    },
    {
      "name": "QBO_REALM_ID",
      "description": "QuickBooks Online company ID (realm ID)",
      "isRequired": true,
      "isSecret": false
    }
  ]
}
